# minimal p=6% 350ppm
# slow p=10% 450ppm
# moderate p=47% 550ppm
# rapid p=37% 650ppm
## What are the mean and standard deviation of the carbon dioxide atmosphere for these trees in ppm?
rapid <- 650
moderate <- 550
slow <- 450
minimal <- 350
## Mean calculation
# 650 + 550 + 450 + 350 = 2000
# 2000 / 4 = 500
# create a vector
mean_vector <- c(rapid, moderate, slow, minimal)
# calculate and print the mean
mean_value <- mean(mean_vector)
# print(sprintf("The mean is %sppm", mean_value))
## Standard Deviation calculation
# 1. find the mean  = 500
# 2. subtract the mean from all the values
# 650 - 500 = 150
# 550 - 500 = 50
# 450 - 500 = -50
# 350 - 500 = -150
a = rapid - mean_value
b = moderate - mean_value
c = slow - mean_value
d = minimal - mean_value
# 3. Square the results
# 150 * 150 = 22500
# 50 * 50 = 2500
# (-50) * (-50) = 2500
# (-150) * (-150) = 22500
a_2 = a * a
b_2 = b * b
c_2 = c * c
d_2 = d * d
my_variance_vector <- c(a_2, b_2, c_2, d_2)
# print(my_variance_vector)
# 4. Find the mean of the squared deviations (the variance)
my_variance_mean <- mean(my_variance_vector)
# print(my_variance_mean)
standard_deviation <- sqrt(my_variance_mean)
# print(standard_deviation)
print("***** The final result *****")
print(sprintf("The Mean is %sppm.", mean_value))
print(sprintf("Standard Deviation is %.1fppm.", + standard_deviation))
