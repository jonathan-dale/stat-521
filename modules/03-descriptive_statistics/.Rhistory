# 70% failure rate --> p(fail) = .7
# p(success) --> 1 - p(fail) = 1 - .7 = .3
p_fail <- .7
p_pass <- 1 - p_fail
num_startups <- 50
p_35_or_more_fail <- num_startups * p_fail
if (p_35_or_more_fail) {
print("True")
}else
print("False")
